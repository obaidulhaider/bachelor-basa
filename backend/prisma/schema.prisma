generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())

  houses House[]
}

model House {
  id            Int      @id @default(autoincrement())
  title         String
  rent          Int
  location      String
  university    String
  ownerName     String
  ownerPhone    String
  description   String
  availableFrom DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  postedById Int?
  postedBy   User? @relation(fields: [postedById], references: [id])
}

enum Role {
  USER
  ADMIN
}